.DS_Store

# Claude Code per-machine state (CLAUDE.md and .claude/ are tracked)
.claude/settings.local.json

# vault content stays out of the public repo — only the .gitkeep
# placeholders are tracked (if you're using this template to version your
# own private vault, delete this block)
Songs/*
!Songs/.gitkeep
Artists/*
!Artists/.gitkeep
Attachments/Covers/*
!Attachments/Covers/.gitkeep

# Obsidian per-user state — keep the shipped config, not session data
# (hotkeys.json IS shipped: it pre-binds the Guitarchive commands)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/app.json
.obsidian/core-plugins.json
.obsidian/graph.json
.obsidian/cache

# installed plugin code (users install these themselves; settings ship in-repo)
.obsidian/plugins/*/main.js
.obsidian/plugins/*/manifest.json
.obsidian/plugins/*/styles.css

# dev-only tooling deps (tools/ is export-ignored; package-lock.json is
# tracked for reproducibility, node_modules is not)
tools/node_modules
